{
  "name": "@cto.af/monopub",
  "version": "1.2.5",
  "decription": "Simplified version and publish from a monorepo",
  "main": "lib/index.js",
  "type": "module",
  "bin": {
    "monopub": "bin/monopub.js"
  },
  "files": [
    "bin/",
    "lib/"
  ],
  "keywords": [
    "monorepo",
    "publish",
    "lerna"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cto-af/monopub.git"
  },
  "homepage": "https://github.com/cto-af/monopub#readme",
  "bugs": {
    "url": "https://github.com/cto-af/monopub/issues"
  },
  "scripts": {
    "clean": "rm -rf coverage docs lib",
    "lint": "eslint .",
    "snaps": "UPDATE_SNAPSHOT=1 node --test test/cli.test.js",
    "pretest": "npm run ts -- --inlineSourceMap",
    "test": "c8 node --test",
    "test:versions": "nve --continue --arch x64 --parallel 18,20,22,23 node --test --test-reporter=dot",
    "posttest": "npm run ts",
    "docs": "typedoc",
    "ts": "tsgo",
    "build": "npm run test && npm run lint && npm run docs && npm pack --dry-run"
  },
  "dependencies": {
    "commander": "~14.0.3",
    "fast-glob": "~3.3.3",
    "simple-git": "~3.36.0",
    "yaml": "~2.8.4"
  },
  "devDependencies": {
    "@cto.af/eslint-config": "^7.0.1",
    "@eslint/markdown": "^8.0.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260502.1",
    "eslint": "^10.3.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "snappy-snaps": "^1.1.0",
    "superc8": "^12.3.1",
    "typedoc": "^0.28.19",
    "typescript-eslint": "^8.59.1"
  },
  "packageManager": "pnpm@11.0.3",
  "engines": {
    "node": ">=22"
  }
}
